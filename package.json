{
  "name": "@the-portland-company/devnotes",
  "version": "0.4.0",
  "description": "Forge-backed DevNotes and bug reporting for React and Next.js apps",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-portland-company/devnotes.git"
  },
  "homepage": "https://github.com/the-portland-company/devnotes",
  "bugs": {
    "url": "https://github.com/the-portland-company/devnotes/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/server/next.d.ts",
      "import": "./dist/server/next.mjs",
      "require": "./dist/server/next.js"
    },
    "./express": {
      "types": "./dist/server/express.d.ts",
      "import": "./dist/server/express.mjs",
      "require": "./dist/server/express.js"
    },
    "./deno": {
      "types": "./dist/server/deno.d.ts",
      "import": "./dist/server/deno.mjs",
      "require": "./dist/server/deno.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "bin": {
    "devnotes-setup": "bin/setup.js"
  },
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup && tailwindcss -i src/styles.css -o dist/styles.css --minify",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test test/**/*.test.mjs",
    "release:check": "npm run typecheck && npm run test && npm pack --dry-run",
    "prepublishOnly": "npm run release:check"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "react-icons": "^4.12.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "license": "MIT",
  "keywords": [
    "react",
    "bug-reporting",
    "devnotes",
    "forge",
    "nextjs",
    "developer-tools"
  ]
}
